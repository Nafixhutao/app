<?xml version="1.0" encoding="utf-8"?>
<!-- Tombol terang (putih) gaya brutalism untuk UNDO -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="6dp" android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_black" />
        </shape>
    </item>
    <item android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_white" />
            <stroke android:width="4dp" android:color="@color/brutal_black" />
        </shape>
    </item>
</layer-list>
