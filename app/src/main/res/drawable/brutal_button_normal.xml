<?xml version="1.0" encoding="utf-8"?>
<!-- Tombol brutalism: kotak pink, border hitam tebal, hard-shadow hitam di kanan-bawah -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Lapisan bayangan (hitam solid, tanpa blur) -->
    <item android:left="8dp" android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_black" />
        </shape>
    </item>

    <!-- Permukaan tombol -->
    <item android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_accent" />
            <stroke android:width="4dp" android:color="@color/brutal_black" />
        </shape>
    </item>

</layer-list>
