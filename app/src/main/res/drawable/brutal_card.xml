<?xml version="1.0" encoding="utf-8"?>
<!-- Kartu nama brutalism: cyan solid + border tebal + hard shadow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="10dp" android:top="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_black" />
        </shape>
    </item>
    <item android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_card" />
            <stroke android:width="4dp" android:color="@color/brutal_black" />
        </shape>
    </item>
</layer-list>
